---
import MatrixRain from "../components/MatrixRain.astro";

const {
  title = "Tyler Rivers | Portfolio",
  links = [
    { name: "Home", href: "/" },
    { name: "Projects", href: "/projects/" },
    { name: "CTF Writeups", href: "/writeups/" },
    { name: "Contact", href: "/contact/" },
    { name: "Resume", href: "/Resume.pdf", external: true },
    { name: "GitHub", href: "https://github.com/tyler-rivers23", external: true },
  ],
} = Astro.props;
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>

    <style>
      body {
        margin: 0;
        color: #e8eef6;
        background-color: #06090f;
        min-height: 100vh;

        /* Grid + glow background */
        background-image:
          linear-gradient(rgba(255,255,255,0.05) 1px, transparent 1px),
          linear-gradient(90deg, rgba(255,255,255,0.05) 1px, transparent 1px),
          radial-gradient(circle at 18% 18%, rgba(0, 255, 140, 0.20), transparent 45%),
          radial-gradient(circle at 82% 28%, rgba(0, 180, 255, 0.14), transparent 45%);
        background-size: 40px 40px, 40px 40px, auto, auto;
      }

      a, a:visited { color: rgba(120,255,200,0.95); text-decoration: none; }
      a:hover { text-decoration: underline; }

      .page {
        max-width: 1100px;
        margin: 0 auto;
        padding: 18px 18px 40px;
        position: relative;
        z-index: 1; /* above Matrix canvas */
      }

      .nav {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 14px;
        flex-wrap: wrap;
        padding: 10px 6px;
      }

      .brand {
        display: flex;
        align-items: baseline;
        gap: 10px;
      }

      .brand a, .brand a:visited { color: #e8eef6; text-decoration: none; }
      .brand a:hover { text-decoration: none; }

      .links { display: flex; gap: 16px; flex-wrap: wrap; }

      .panel {
        margin-top: 18px;
        padding: 28px;
        border-radius: 18px;
        background: rgba(10, 18, 24, 0.75);
        border: 1px solid rgba(255,255,255,0.10);
        backdrop-filter: blur(14px);
        box-shadow: 0 25px 80px rgba(0,0,0,0.45);
      }

      .muted { color: #a9b4c2; }

      .btn {
        display: inline-block;
        border: 1px solid rgba(255,255,255,0.12);
        padding: 10px 14px;
        border-radius: 12px;
        background: rgba(255,255,255,0.03);
        color: rgba(120,255,200,0.95);
      }
      .btn:hover { text-decoration: none; filter: brightness(1.1); }

      code {
        font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, "Liberation Mono", monospace;
      }
    </style>
  </head>

  <body>
    <MatrixRain opacity={0.12} fontSize={18} speed={0.35} />

    <div class="page">
      <div class="nav">
        <div class="brand">
          <a href="/"><strong>Tyler Rivers</strong></a>
          <span class="muted">| Cybersecurity</span>
        </div>

        <div class="links">
          {links.map((l) =>
            l.external ? (
              <a href={l.href} target="_blank" rel="noreferrer">{l.name}</a>
            ) : (
              <a href={l.href}>{l.name}</a>
            )
          )}
        </div>
      </div>

      <div class="panel">
        <slot />
      </div>
    </div>
  </body>
</html>