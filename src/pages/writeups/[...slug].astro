---
import MainLayout from "../../layouts/MainLayout.astro";
import DownloadButtons from "../../components/DownloadButtons.astro";
import { getCollection } from "astro:content";

export const prerender = true;

export async function getStaticPaths() {
  const writeups = await getCollection("writeups");
  return writeups.map((w) => ({
    params: { slug: w.slug },
    props: { w },
  }));
}

const { w } = Astro.props;
const { Content } = await w.render();
---

<MainLayout title={`${w.data.title} | Tyler Rivers`} pageClass="writeup-terminal">
  <h1>{w.data.title}</h1>
  <p class="muted">
    {w.data.ctf}{w.data.difficulty ? ` • ${w.data.difficulty}` : ""} • {w.data.date.toLocaleDateString()}
  </p>

  <div style="display:flex; gap: 12px; flex-wrap: wrap; margin: 12px 0 16px;">
    <a class="btn" href="/writeups/">← Back to CTF Writeups</a>
  </div>

  <DownloadButtons source={w.data.source} asm={w.data.asm} />

  <Content />
</MainLayout>