---
import MainLayout from "../../layouts/MainLayout.astro";
import { getCollection } from "astro:content";

const items = (await getCollection("writeups")).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);
---

<MainLayout title="CTF Writeups | Tyler Rivers">
  <h1 style="margin:0 0 10px 0;">CTF Writeups</h1>
  <div class="muted">Writeups from picoCTF, BearcatCTF, etc.</div>

  <div style="margin-top:16px;">
    {items.map((w) => (
      <div style="padding:14px 0; border-top:1px solid rgba(255,255,255,0.08);">
        <h2 style="margin:0;">
          <a href={`/writeups/${w.slug}/`} style="color:#e8eef6; text-decoration:none;">
            {w.data.title}
          </a>
        </h2>
        <div class="muted" style="margin-top:6px;">
          {w.data.ctf}{w.data.difficulty ? ` • ${w.data.difficulty}` : ""} • {w.data.date.toLocaleDateString()}
          <br />{w.data.summary}
        </div>
      </div>
    ))}
  </div>
</MainLayout>