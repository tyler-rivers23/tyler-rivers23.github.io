---
import MainLayout from "../../layouts/MainLayout.astro";
import { getCollection } from "astro:content";

export const prerender = true;

export async function getStaticPaths() {
  const projects = await getCollection("projects");
  return projects.map((p) => ({
    params: { slug: p.slug },
    props: { p },
  }));
}

const { p } = Astro.props;
const { Content } = await p.render();
---

<MainLayout title={`${p.data.title} | Tyler Rivers`} pageClass="">
  <h1>{p.data.title}</h1>
  <p class="muted">{p.data.date.toLocaleDateString()} • {p.data.summary}</p>

  <div style="display:flex; gap:10px; flex-wrap:wrap; margin: 12px 0 18px;">
    {p.data.github && <a class="btn" href={p.data.github} target="_blank" rel="noreferrer">GitHub</a>}
    {p.data.demo && <a class="btn" href={p.data.demo} target="_blank" rel="noreferrer">Live Demo</a>}
    <a class="btn" href="/projects/">← Back to Projects</a>
  </div>

  <Content />
</MainLayout>