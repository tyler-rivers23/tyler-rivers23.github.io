---
import { getCollection } from "astro:content";
const items = (await getCollection("projects"))
  .sort((a,b) => b.data.date.valueOf() - a.data.date.valueOf());
---

<html>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Projects | Tyler Rivers</title>
    <style>
      body { font-family: system-ui; max-width: 1000px; margin: 30px auto; padding: 0 16px; }
      .card { border: 1px solid #ddd; border-radius: 14px; padding: 14px 16px; margin: 12px 0; }
      .meta { color: #666; }
      .tags { display:flex; gap:6px; flex-wrap:wrap; margin-top:8px; }
      .tag { border:1px solid #ddd; border-radius: 999px; padding: 2px 10px; font-size: 0.85rem; }
      a { color: inherit; }
    </style>
  </head>
  <body>
    <a href="/">← Home</a>
    <h1>Projects</h1>
    {items.map(p => (
      <div class="card">
        <h2 style="margin:0"><a href={`/projects/${p.slug}/`}>{p.data.title}</a></h2>
        <div class="meta">{p.data.date.toLocaleDateString()} • {p.data.summary}</div>
        <div class="tags">{p.data.tags.map(t => <span class="tag">{t}</span>)}</div>
      </div>
    ))}
  </body>
</html>