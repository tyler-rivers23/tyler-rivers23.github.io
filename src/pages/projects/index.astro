---
import MainLayout from "../../layouts/MainLayout.astro";
import { getCollection } from "astro:content";

const items = (await getCollection("projects"))
  .sort((a,b) => b.data.date.valueOf() - a.data.date.valueOf());
---

<MainLayout title="Projects | Tyler Rivers">
  <h1>Projects</h1>

  {items.map(p => (
    <div style="margin: 16px 0;">
      <h2 style="margin:0">
        <a href={`/projects/${p.slug}/`}>{p.data.title}</a>
      </h2>
      <p class="muted" style="margin:6px 0 0 0;">
        {p.data.date.toLocaleDateString()} • {p.data.summary}
      </p>
      <div style="display:flex; gap:8px; flex-wrap:wrap; margin-top:10px;">
        {p.data.tags?.map(t => <span style="border:1px solid rgba(255,255,255,0.14); padding:2px 10px; border-radius:999px; font-size:0.85rem; color:#a9b4c2;">{t}</span>)}
      </div>
    </div>
  ))}
</MainLayout>