---
interface Props {
  source?: string;
  asm?: string;
}

const { source, asm } = Astro.props;
---


<div style="display:flex; gap: 12px; flex-wrap: wrap; margin: 0 0 14px 0;">
  {source && (
    <a class="btn" href={source} download>
      ⬇ Download Source Code
    </a>
  )}
  {asm && (
    <a class="btn" href={asm} download>
      ⬇ Download Assembly
    </a>
  )}
</div>

<style>
.download-buttons {
  display: flex;
  gap: 1rem;
  margin: 1.5rem 0;
}

.download-btn {
  background: #0f172a;
  color: #22c55e;
  padding: 0.6rem 1rem;
  border-radius: 6px;
  font-family: monospace;
  text-decoration: none;
  border: 1px solid #22c55e;
  transition: all 0.2s ease;
}

.download-btn:hover {
  background: #22c55e;
  color: #0f172a;
}
</style>